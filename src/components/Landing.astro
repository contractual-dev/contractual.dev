---
// Landing.astro - Technical project page for contractual.dev (v2)
---

<div class="landing-root">

  <!-- ============================================================ -->
  <!-- STICKY HEADER                                                 -->
  <!-- ============================================================ -->
  <header class="landing-header">
    <div class="header-inner">
      <a href="/" class="header-logo">Contractual</a>
      <nav class="header-nav">
        <a href="/getting-started/" class="header-link">Docs</a>
        <a href="/blog/" class="header-link">Blog</a>
        <a
          href="https://github.com/contractual-dev/contractual"
          target="_blank"
          rel="noopener noreferrer"
          class="header-github"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.868-.013-1.703-2.782.604-3.369-1.34-3.369-1.34-.454-1.155-1.11-1.463-1.11-1.463-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836a9.59 9.59 0 012.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.741 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z" />
          </svg>
          <span class="github-stars">Star</span>
        </a>
      </nav>
    </div>
  </header>

  <!-- ============================================================ -->
  <!-- 1. HERO                                                       -->
  <!-- ============================================================ -->
  <section class="hero-section">
    <div class="hero-bg-animation" aria-hidden="true">
      <div class="hero-orb hero-orb-1"></div>
      <div class="hero-orb hero-orb-2"></div>
      <div class="hero-orb hero-orb-3"></div>
    </div>
    <div class="hero-inner">
      <div class="hero-content">
        <div class="hero-badge">
          <span class="badge-dot"></span>
          Open Source &middot; CLI + GitHub Action
        </div>

        <h1 class="hero-headline">
          Stop guessing what broke.
        </h1>

        <p class="hero-subhead">
          Lint, detect breaking changes, version, and release your API contracts from a single config file.
        </p>

        <div class="hero-actions">
          <a href="/getting-started/" class="btn-primary">Get Started</a>
          <a
            href="https://github.com/contractual-dev/contractual"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-secondary"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.868-.013-1.703-2.782.604-3.369-1.34-3.369-1.34-.454-1.155-1.11-1.463-1.11-1.463-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836a9.59 9.59 0 012.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.741 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z" />
            </svg>
            GitHub
          </a>
        </div>
      </div>

      <div class="hero-terminal-wrap">
        <div class="terminal">
          <div class="terminal-header">
            <span class="terminal-dot terminal-dot-red"></span>
            <span class="terminal-dot terminal-dot-yellow"></span>
            <span class="terminal-dot terminal-dot-green"></span>
            <span class="terminal-title">contractual</span>
          </div>
          <div class="terminal-content">
            <div>
              <span class="terminal-prompt">$</span>
              <span class="terminal-command"> contractual breaking</span>
            </div>
            <div class="terminal-spacer"></div>
            <div>
              <span class="terminal-breaking">&#x2717;</span>
              <span class="terminal-dim"> orders-api: </span>
              <span class="terminal-breaking">2 breaking changes</span>
            </div>
            <div class="terminal-indent">
              <span class="badge-breaking-sm">BREAKING</span>
              <span class="terminal-dim"> Removed endpoint </span>
              <span class="terminal-code">GET /orders/{'{'}id{'}'}/details</span>
            </div>
            <div class="terminal-indent">
              <span class="badge-breaking-sm">BREAKING</span>
              <span class="terminal-dim"> Changed type of field </span>
              <span class="terminal-code">'amount'</span>
              <span class="terminal-dim">: </span>
              <span class="terminal-breaking">string &rarr; number</span>
            </div>
            <div class="terminal-spacer"></div>
            <div>
              <span class="terminal-success">&#x2713;</span>
              <span class="terminal-dim"> order-schema: </span>
              <span class="terminal-success">1 non-breaking change</span>
            </div>
            <div class="terminal-indent">
              <span class="badge-minor-sm">MINOR</span>
              <span class="terminal-dim"> Added optional field </span>
              <span class="terminal-code">'shipping_address'</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- 2. THE PROBLEM                                                -->
  <!-- ============================================================ -->
  <section class="section section-alt">
    <div class="section-inner">
      <div class="section-header">
        <span class="section-eyebrow">The problem</span>
        <h2 class="section-headline">Every schema ecosystem needs the same lifecycle.</h2>
      </div>

      <div class="problem-cards">
        <div class="problem-card">
          <h3 class="problem-card-title">Fragmented tooling</h3>
          <p class="problem-card-body">ajv for JSON Schema. Scattered tools for OpenAPI. Nothing for AsyncAPI or ODCS. No single tool handles lint, breaking changes, versioning, and release across formats.</p>
        </div>

        <div class="problem-card">
          <h3 class="problem-card-title">No JSON Schema differ</h3>
          <p class="problem-card-body">150M+ weekly downloads. No production tooling for breaking change detection. The JSON Schema org is <a href="https://github.com/json-schema-org/community/issues/984" target="_blank" rel="noopener noreferrer" class="problem-card-link">building one</a> via GSoC 2026.</p>
        </div>

        <div class="problem-card">
          <h3 class="problem-card-title">No versioning for specs</h3>
          <p class="problem-card-body">Packages have npm. Protobuf has Buf's registry. API specs and schemas have nothing &mdash; no version history, no changelogs, no release workflow.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- 3. HOW IT WORKS                                              -->
  <!-- ============================================================ -->
  <section class="section">
    <div class="section-inner">
      <div class="section-header">
        <span class="section-eyebrow">How it works</span>
        <h2 class="section-headline">Three steps.</h2>
      </div>

      <div class="steps-grid">
        <div class="step-card">
          <div class="step-number">01</div>
          <h3 class="step-title">Configure once</h3>
          <p class="step-body">
            Run <code>contractual init</code> and Contractual walks your repo, detects
            your specs, and scaffolds a config file. Declare your contracts once.
          </p>
          <div class="step-code">
            <pre><code><span class="code-comment"># contractual.config.yaml</span>
contracts:
  - name: orders-api
    type: openapi
    path: ./specs/orders.yaml
  - name: order-schema
    type: json-schema
    path: ./schemas/order.json</code></pre>
          </div>
        </div>

        <div class="step-card">
          <div class="step-number">02</div>
          <h3 class="step-title">Changes detected automatically</h3>
          <p class="step-body">
            On every pull request, the GitHub Action runs <code>contractual breaking</code>
            and posts a structured diff table directly in the PR.
          </p>
          <div class="step-visual">
            <div class="step-visual-card">
              <div class="pr-comment-header">
                <span class="pr-bot-badge">contractual-bot</span>
                <span class="pr-comment-meta">commented on this PR</span>
              </div>
              <div class="pr-comment-body">
                <p class="pr-comment-title">Breaking change detected in <code>orders-api</code></p>
                <table class="pr-diff-table">
                  <thead>
                    <tr>
                      <th>Type</th>
                      <th>Change</th>
                    </tr>
                  </thead>
                  <tbody>
                    <tr>
                      <td><span class="badge-inline badge-inline-breaking">BREAKING</span></td>
                      <td>Removed <code>GET /orders/{'{'}id{'}'}/details</code></td>
                    </tr>
                    <tr>
                      <td><span class="badge-inline badge-inline-minor">MINOR</span></td>
                      <td>Added optional field <code>shipping_address</code></td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>

        <div class="step-card">
          <div class="step-number">03</div>
          <h3 class="step-title">Versions managed for you</h3>
          <p class="step-body">
            Run <code>contractual version</code> to consume changesets, bump SemVer,
            generate changelogs, and open a "Version Contracts" PR automatically.
          </p>
          <div class="step-visual">
            <div class="step-visual-card">
              <div class="pr-comment-header">
                <span class="pr-bot-badge">contractual-bot</span>
                <span class="pr-comment-meta">opened pull request</span>
              </div>
              <div class="pr-comment-body">
                <p class="pr-comment-title">Version Contracts: orders-api@2.0.0</p>
                <ul class="pr-version-list">
                  <li><span class="text-green">+</span> CHANGELOG.md updated</li>
                  <li><span class="text-green">+</span> orders-api bumped 1.3.0 &rarr; 2.0.0</li>
                  <li><span class="text-green">+</span> Changeset file consumed</li>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- 4. WHAT IT DOES (feature grid)                               -->
  <!-- ============================================================ -->
  <section class="section section-alt">
    <div class="section-inner">
      <div class="section-header">
        <span class="section-eyebrow">Features</span>
        <h2 class="section-headline">Schema contract lifecycle, end to end.</h2>
      </div>

      <div class="feature-grid-landing">
        <div class="feature-card-landing">
          <div class="feature-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <polyline points="22 12 18 12 15 21 9 3 6 12 2 12" />
            </svg>
          </div>
          <h3 class="feature-title">Structural diffing</h3>
          <p class="feature-desc">
            Compares specs at the semantic level, not line-by-line. Detects removals, type
            changes, and constraint tightening that break consumers.
          </p>
        </div>

        <div class="feature-card-landing">
          <div class="feature-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <rect x="2" y="3" width="20" height="14" rx="2" ry="2" />
              <line x1="8" y1="21" x2="16" y2="21" />
              <line x1="12" y1="17" x2="12" y2="21" />
            </svg>
          </div>
          <h3 class="feature-title">Multi-format</h3>
          <p class="feature-desc">
            One CLI for OpenAPI, JSON Schema, AsyncAPI, and ODCS. One config file. One command
            per lifecycle step. No tool sprawl across formats.
          </p>
        </div>

        <div class="feature-card-landing">
          <div class="feature-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
            </svg>
          </div>
          <h3 class="feature-title">Auto-classification</h3>
          <p class="feature-desc">
            Every detected change is classified as breaking, minor, or patch following SemVer
            semantics. Developers can override when needed.
          </p>
        </div>

        <div class="feature-card-landing">
          <div class="feature-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <circle cx="12" cy="18" r="3" />
              <circle cx="6" cy="6" r="3" />
              <circle cx="18" cy="6" r="3" />
              <line x1="18" y1="9" x2="18" y2="12" />
              <line x1="12" y1="15" x2="12" y2="12" />
              <line x1="6" y1="9" x2="6" y2="12" />
              <line x1="6" y1="12" x2="18" y2="12" />
            </svg>
          </div>
          <h3 class="feature-title">GitHub-native</h3>
          <p class="feature-desc">
            PR comments, status checks, and automated Version PRs through the official GitHub
            Action. No extra infrastructure required.
          </p>
        </div>

        <div class="feature-card-landing">
          <div class="feature-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
            </svg>
          </div>
          <h3 class="feature-title">AI explanations <span class="feature-badge-optional">optional</span></h3>
          <p class="feature-desc">
            Connect an LLM to generate human-readable migration guides and draft changelog entries.
            Contractual functions without it.
          </p>
        </div>

        <div class="feature-card-landing">
          <div class="feature-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <polyline points="16 3 21 3 21 8" />
              <line x1="4" y1="20" x2="21" y2="3" />
              <polyline points="21 16 21 21 16 21" />
              <line x1="15" y1="15" x2="21" y2="21" />
            </svg>
          </div>
          <h3 class="feature-title">Extensible</h3>
          <p class="feature-desc">
            Plug in custom linters and differs via the plugin API. Use <code class="inline-code">{'{'}spec{'}'}</code>,
            <code class="inline-code">{'{'}old{'}'}</code>, <code class="inline-code">{'{'}new{'}'}</code> placeholders in any shell command.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- 5. HOW IT FITS (orchestration diagram)                       -->
  <!-- ============================================================ -->
  <section class="section">
    <div class="section-inner">
      <div class="section-header">
        <span class="section-eyebrow">How it fits</span>
        <h2 class="section-headline">An orchestration layer, not a replacement.</h2>
      </div>

      <div class="orchestration-wrap">
        <div class="orch-row">
          <div class="orch-label orch-label-top">Your existing tools:</div>
          <div class="orch-box orch-box-top">
            <div class="orch-cols">
              <div class="orch-col">
                <div class="orch-col-head">Linters</div>
                <div class="orch-tool">Spectral</div>
                <div class="orch-tool">Redocly</div>
                <div class="orch-tool">ajv</div>
              </div>
              <div class="orch-col">
                <div class="orch-col-head">Differs</div>
                <div class="orch-tool">Built-in structural differ</div>
                <div class="orch-tool orch-tool-dim">(nothing for JSON Schema)</div>
              </div>
              <div class="orch-col">
                <div class="orch-col-head">Generators</div>
                <div class="orch-tool">Orval</div>
                <div class="orch-tool">openapi-ts</div>
                <div class="orch-tool">quicktype</div>
              </div>
            </div>
          </div>
        </div>

        <div class="orch-arrow-row" aria-hidden="true">
          <div class="orch-arrow-line"></div>
          <div class="orch-arrow-text">Contractual orchestrates them</div>
          <div class="orch-arrow-line"></div>
        </div>

        <div class="orch-row">
          <div class="orch-label orch-label-bottom">Contractual adds:</div>
          <div class="orch-box orch-box-bottom">
            <div class="orch-pipeline">
              <span class="orch-step">lint</span>
              <span class="orch-arrow-inline">&rarr;</span>
              <span class="orch-step">breaking</span>
              <span class="orch-arrow-inline">&rarr;</span>
              <span class="orch-step">changeset</span>
              <span class="orch-arrow-inline">&rarr;</span>
              <span class="orch-step">version</span>
              <span class="orch-arrow-inline">&rarr;</span>
              <span class="orch-step">release</span>
            </div>
            <ul class="orch-adds">
              <li><span class="orch-plus">+</span> Built-in JSON Schema structural differ</li>
              <li><span class="orch-plus">+</span> GitHub PR comments &amp; Version PRs</li>
              <li><span class="orch-plus">+</span> Optional AI explanations</li>
            </ul>
          </div>
        </div>
      </div>

      <p class="orchestration-summary">
        Contractual wraps existing linters and differs through a declarative config. It adds
        versioning, changelogs, and release management. For JSON Schema, it includes a built-in
        structural differ.
      </p>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- 6. SUPPORTED FORMATS                                         -->
  <!-- ============================================================ -->
  <section class="section section-alt">
    <div class="section-inner">
      <div class="section-header">
        <span class="section-eyebrow">Supported formats</span>
        <h2 class="section-headline">One config. Every spec format.</h2>
      </div>

      <div class="formats-grid">
        <div class="format-card-landing">
          <div class="format-logo format-logo-blue">OA</div>
          <h3 class="format-name">OpenAPI</h3>
          <ul class="format-details">
            <li>Redocly lint</li>
            <li>Built-in differ</li>
          </ul>
          <span class="format-status format-status-ga">GA</span>
        </div>

        <div class="format-card-landing">
          <div class="format-logo format-logo-green">JS</div>
          <h3 class="format-name">JSON Schema</h3>
          <ul class="format-details">
            <li>ajv validation</li>
            <li>Built-in differ</li>
          </ul>
          <span class="format-status format-status-ga">GA</span>
        </div>

        <div class="format-card-landing format-card-coming">
          <div class="format-logo format-logo-orange">AS</div>
          <h3 class="format-name">AsyncAPI</h3>
          <ul class="format-details">
            <li>@asyncapi/parser</li>
            <li>Built-in differ</li>
          </ul>
          <span class="format-status format-status-coming">Coming soon</span>
        </div>

        <div class="format-card-landing format-card-coming">
          <div class="format-logo format-logo-purple">OD</div>
          <h3 class="format-name">ODCS</h3>
          <ul class="format-details">
            <li>ajv vs ODCS schema</li>
            <li>Built-in differ</li>
          </ul>
          <span class="format-status format-status-coming">Coming soon</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- 7. CLI COMMANDS AT A GLANCE                                  -->
  <!-- ============================================================ -->
  <section class="section">
    <div class="section-inner">
      <div class="section-header">
        <span class="section-eyebrow">CLI reference</span>
        <h2 class="section-headline">Six commands. Complete lifecycle.</h2>
      </div>

      <div class="cli-grid">
        <div class="terminal cli-terminal">
          <div class="terminal-header">
            <span class="terminal-dot terminal-dot-red"></span>
            <span class="terminal-dot terminal-dot-yellow"></span>
            <span class="terminal-dot terminal-dot-green"></span>
          </div>
          <div class="terminal-content cli-commands">
            <div class="cli-row">
              <span class="cli-cmd">contractual init</span>
              <span class="cli-desc">Detect specs, scaffold config</span>
            </div>
            <div class="cli-row">
              <span class="cli-cmd">contractual lint</span>
              <span class="cli-desc">Validate all contracts</span>
            </div>
            <div class="cli-row">
              <span class="cli-cmd">contractual breaking</span>
              <span class="cli-desc">Detect breaking changes vs last version</span>
            </div>
            <div class="cli-row">
              <span class="cli-cmd">contractual changeset</span>
              <span class="cli-desc">Generate changeset from detected changes</span>
            </div>
            <div class="cli-row">
              <span class="cli-cmd">contractual version</span>
              <span class="cli-desc">Consume changesets, bump versions, changelog</span>
            </div>
            <div class="cli-row">
              <span class="cli-cmd">contractual status</span>
              <span class="cli-desc">Show versions and pending changesets</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- 8. JSON SCHEMA DIFFER                                        -->
  <!-- ============================================================ -->
  <section class="section section-alt">
    <div class="section-inner">
      <div class="section-header">
        <span class="section-eyebrow">JSON Schema</span>
        <h2 class="section-headline">Built-in JSON Schema breaking change detection.</h2>
        <p class="section-subhead">
          JSON Schema has no equivalent to <code>buf breaking</code>.
          Contractual includes a structural differ that walks two schema versions, resolves
          <code>$ref</code>, and classifies every change.
        </p>
      </div>

      <div class="schema-table-wrap">
        <table class="classification-table schema-table">
          <thead>
            <tr>
              <th>Change</th>
              <th>Classification</th>
              <th>Reason</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Remove required property</td>
              <td><span class="badge-inline badge-inline-breaking">Breaking</span></td>
              <td>Consumers may depend on the property being present</td>
            </tr>
            <tr>
              <td>Narrow <code>type</code> (e.g. <code>string|number</code> &rarr; <code>string</code>)</td>
              <td><span class="badge-inline badge-inline-breaking">Breaking</span></td>
              <td>Previously valid data is now rejected</td>
            </tr>
            <tr>
              <td>Add <code>enum</code> constraint to existing field</td>
              <td><span class="badge-inline badge-inline-breaking">Breaking</span></td>
              <td>Restricts previously accepted values</td>
            </tr>
            <tr>
              <td>Decrease <code>maxLength</code></td>
              <td><span class="badge-inline badge-inline-breaking">Breaking</span></td>
              <td>Previously valid data may now fail validation</td>
            </tr>
            <tr>
              <td>Add optional property</td>
              <td><span class="badge-inline badge-inline-minor">Minor</span></td>
              <td>Backwards-compatible extension</td>
            </tr>
